<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EJS Demo</title>
    <!-- Serving Static File -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="card">
        <h1>Welcome to EJS!</h1>
        <p>This page is rendered dynamically using a Template Engine.</p>
        
        <h3>Current Server Time:</h3>
        <p><%= time %></p>

        <h3>Dynamic List:</h3>
        <ul>
            <% items.forEach(item => { %>
                <li><%= item %></li>
            <% }); %>
        </ul>
    </div>
</body>
</html>
